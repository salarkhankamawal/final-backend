# Server
PORT=8000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/travel-agency

# Auth
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=7d

# Resend (email) — optional, for ticket emails on booking confirm
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=tickets@yourdomain.com

# SMTP Email settings for Nodemailer
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-email-password
EMAIL_FROM_NAME="Nawi Saadi Travel Agency"
EMAIL_FROM_EMAIL=your-email@gmail.com

